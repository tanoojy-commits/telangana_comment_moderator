GEMINI_API_KEY=your_gemini_api_key_here
USE_MYSQL=true
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DB=telangana_moderation
SECRET_KEY=your_secret_key_here

